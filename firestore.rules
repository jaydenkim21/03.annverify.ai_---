rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 탈퇴 계정 기록 — 클라이언트 읽기/쓰기 허용 (서버에서 관리)
    match /deleted_accounts/{docId} {
      allow read, write: if true;
    }

    // 사용자 문서 (구독 정보 등) — 본인만 읽기/쓰기 가능
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 사용자 히스토리 — 본인만 읽기/쓰기 가능
    match /users/{uid}/history/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // 커뮤니티 댓글 — 본인만 읽기/쓰기 가능
    match /users/{uid}/communityComments/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // 커뮤니티 투표 — 본인만 읽기/쓰기 가능
    match /users/{uid}/communityVotes/{docId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Partner News 팩트체크 결과 공유 — 누구나 읽기, 로그인 사용자만 쓰기
    match /partnerVerified/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Partner News 기사 — 누구나 읽기, 로그인 사용자 생성/지정 필드 업데이트 허용
    match /partnerNews/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['grade','score','verdict_class','verifiedAt','verifiedCount','title','excerpt','thumb','category','source_label','url','publishedAt','partnerId']);
    }

    // 커뮤니티 포스트 — 누구나 읽기, 로그인 사용자 생성, 지정 필드만 업데이트
    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['yesCount','partialCount','noCount','notSureCount','likeCount','commentCount']);

      // 댓글 — 누구나 읽기, 로그인 사용자 생성, 본인만 수정/삭제
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        allow update: if request.auth != null
          && (resource.data.uid == request.auth.uid
              || request.resource.data.keys().hasOnly(['likeCount','replies']));
        allow delete: if request.auth != null
          && resource.data.uid == request.auth.uid;
      }

      // 투표 — 누구나 읽기, 본인 문서만 쓰기
      match /votes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // AI News 기사 — 누구나 읽기 (Worker가 생성/관리)
    match /aiNews/{docId} {
      allow read: if true;
    }

    // AI News 좋아요 — 누구나 읽기, 로그인 사용자만 쓰기
    match /annLikes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 북마크 — 누구나 읽기, 로그인 사용자만 쓰기
    match /bookmarks/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Partner News 좋아요 — 누구나 읽기, 로그인 사용자만 쓰기
    match /partnerLikes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
